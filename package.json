    "@radix-ui/react-tooltip": "^1.2.8",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fabric": "^5.5.2",
    "framer-motion": "^12.34.3",
    "html2canvas": "^1.4.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
