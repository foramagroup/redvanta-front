    "react-query": "^3.39.3",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5",
    "supports-color": "^10.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
