{
  "name": "krootal-next-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "npx concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "setup": "powershell ./scripts/install/setup.ps1",
    "reset": "powershell ./scripts/reset/reset.ps1",
    "debug": "powershell ./scripts/debug/debug.ps1"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
