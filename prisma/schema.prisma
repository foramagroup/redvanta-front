  @@unique([langId, slug])          // slug must be unique per language
  @@map("product_translation")
}


 model ProductGalleryItem {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String                  // image/video data URL or YouTube embed URL
  type      GalleryItemType         // "image" | "video" | "youtube"
  poster    String?                 // thumbnail for video / YouTube HQ default
  position  Int     @default(0)     // order in the gallery (0 = primary)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_gallery_item")
}

model ProductPackageTier {
  id        Int   @id @default(autoincrement())
  productId Int
  qty       Int   // number of cards
  price     Float // price per card at this qty

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]
  @@unique([productId, qty])
  @@map("product_package_tier")
}

model CartItem {
  id            Int      @id @default(autoincrement())
  userId        Int      @db.UnsignedInt
  companyId     Int
  productId     Int
  packageTierId Int?
  quantity      Int
  totalCards    Int      // = packageTier.qty (snapshot)
  unitPrice     Float    // prix/carte au moment de l'ajout (snapshot)
  lineTotal     Float    // totalCards x unitPrice
  // Options
  cardTypeId    String?
  designId      Int?     @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User                @relation(fields: [userId],       references: [id], onDelete: Cascade)
  company     Company             @relation(fields: [companyId],    references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [productId],    references: [id], onDelete: Cascade)
  packageTier ProductPackageTier?  @relation(fields: [packageTierId], references: [id], onDelete: Restrict)
  design      Design?             @relation(fields: [designId],     references: [id], onDelete: SetNull)
  cardType    CardType?           @relation(fields: [cardTypeId],   references: [id], onDelete: SetNull)

  @@index([userId, companyId])
  @@index([productId])
  @@map("cart_items")
}


model CardTypePrice {
  id         Int    @id @default(autoincrement())
  productId  Int
  cardTypeId String
  price      Float  @default(0)  // additional price on top of base

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  cardType CardType @relation(fields: [cardTypeId], references: [id], onDelete: Cascade)

  @@unique([productId, cardTypeId])
  @@map("card_type_price")
}


