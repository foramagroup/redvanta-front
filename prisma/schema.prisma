generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id             Int              @id @default(autoincrement())
  name           String           @unique(map: "name") @db.VarChar(255)
  createdAt      DateTime         @default(now()) @db.DateTime(0)
  updatedAt      DateTime         @default(now()) @db.DateTime(0)
  users       User[] 
  companies       UserCompany[] 
  rolepermission rolePermission[]
}

model User {
  id               Int             @id @default(autoincrement()) @db.UnsignedInt
  email            String          @unique
  password         String
  companyId        Int?     @db.UnsignedInt
  name             String?
  phone            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isSuperadmin     Boolean         @default(false)
  isAdmin     Boolean         @default(false)
  superadminSince  DateTime?
  superadminLastAt DateTime?
  emailVerifiedAt  DateTime?
  emailVerifyToken String?         @unique @db.VarChar(255)
  emailVerifyExp   DateTime?
  roleId           Int?
  twoFa            Boolean?        @default(false)
  lastLogin        DateTime?       @db.DateTime(0)
  welcomeToken     String?         @unique @db.VarChar(255)
  welcomeTokenExp  DateTime?
  affiliates       Affiliate?
  design           Design[]
  orders Order[]
  cartItems CartItem[]

  logins           LoginActivity[]
  role             Role?       @relation(fields: [roleId], references: [id])
  companies        UserCompany[] 
  refreshTokens RefreshToken[]
  invoices     Invoice[]
  payments    Payment[]
  nfcCards NFCCard[]
  locations    Location[] @relation("OwnerLocations")
  auditLogs AuditLog[] @relation("AdminLogs")
  changedStatuses OrderStatusHistory[] @relation("StatusChangedBy")
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int      @db.UnsignedInt
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_tokens")
}

model UserCompany {
  id        Int      @id @default(autoincrement())
  userId    Int      @db.UnsignedInt
  companyId Int
  roleId    Int?                    // rôle dans CETTE company (peut differ du rôle global)
  isOwner   Boolean  @default(true) // true = admin principal de la company
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role?    @relation(fields: [roleId],    references: [id], onDelete: SetNull)

  @@unique([userId, companyId])   // un user ne peut être lié qu'une fois à une company
  @@index([companyId])
  @@index([userId])
  @@map("user_companies")
}

model PlatformSetting {
  id                   Int         @id @default(autoincrement()) @db.UnsignedInt
  platform_name        String      @db.VarChar(150)
  default_email_sender String      @db.VarChar(150)
  sms_setting_id       Int?        @db.UnsignedInt
  rate_limit           Int         @default(60)
  is_maIntenance       Boolean     @default(false)
  createdAt            DateTime    @default(now()) @db.Timestamp(0)
  updatedAt            DateTime    @default(now()) @db.Timestamp(0)
  smsSetting           SmsSetting? @relation(fields: [sms_setting_id], references: [id])
  @@index([sms_setting_id])
  @@map("platform_settings")
}



model Location {
  id          Int      @id @default(autoincrement())
  companyId   Int              
  ownerId     Int      @db.UnsignedInt 
  name        String   @db.VarChar(255) // "Downtown Flagship"
  address     String?  @db.VarChar(500) // "123 Main St, New York, NY 10001"
  googlePlaceId   String?  @db.VarChar(255)
  googleReviewUrl String?  @db.VarChar(500)
  googleMapsUrl   String?  @db.VarChar(500)
  googleRating     Float?
  googleReviewCount Int?    @default(0)
  cardCount   Int      @default(0)
  city      String?
  postal    String?
  country   String?
  phone     String?
  email     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt



  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner       User     @relation("OwnerLocations", fields: [ownerId], references: [id], onDelete: Cascade)
  nfcCards NFCCard[]
  reviews   Review[]
  feedbacks Feedback[]

  @@index([companyId])
  @@index([googlePlaceId])
  @@index([active])
  @@map("locations")
}



model Conversion {
  id           Int      @id @default(autoincrement())
  orderId      Int
  currency     String   @db.VarChar(10)
  rate         Float
  displayTotal Float
  baseCurrency String   @default("EUR") @db.VarChar(10)
  baseTotal    Float    // montant réel en EUR

  createdAt    DateTime @default(now())

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("conversions")
}


model Review {
  id            String       @id @default(uuid()) @db.Char(36)
  locationId    Int
  userId        String?
  userName      String?
  rating        Int
  comment       String?
  status        ReviewStatus @default(pending)
  email         String?
  phone         String?
  locationSlug  String?
  contact       String?
  source        String?
  notifiedOwner Boolean      @default(false)
  postedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  location      Location     @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([userId], map: "reviews_userId_fkey")
  @@map("reviews")
}




model Order {
 id            Int         @id @default(autoincrement())
  userId        Int         @db.UnsignedInt
  companyId     Int                          // ← company concernée
  orderNumber   String      @unique
  status        OrderStatus @default(pending)

  subtotal      Float
  shippingCost  Float       @default(0)
  total         Float

  methodPayment  String?
  trackingNumber   String?
  trackingUrl      String?
  estimatedDelivery DateTime?
  shippingFullName  String?
  shippingAddress   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?  @default("United States")
  shippingMethod    ShippingMethod @default(standard)

  stripePaymentIntentId String? @unique
  stripeClientSecret    String?
  paidAt                DateTime?
  confirmationEmailSentAt DateTime?

  currency     String?  @default("EUR")
  manualPaymentMethodId Int?
  displayTotal Float?
  exchangeRate Float?   @default(1)

  invoice      Invoice?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId],    references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  paymentMethod     ManualPaymentMethod?   @relation(fields: [manualPaymentMethodId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  Conversions Conversion[]
  payments    Payment[]
  statusHistory OrderStatusHistory[]


  @@index([userId, companyId])
  @@index([status])
  @@map("order")
}

model OrderStatusHistory {
  id          Int         @id @default(autoincrement())
  orderId     Int
  status      OrderStatus
  note        String?     @db.VarChar(500) // note interne du superadmin
  changedBy   Int?        @db.UnsignedInt  // userId du superadmin qui a changé
  changedAt   DateTime    @default(now())

  order       Order       @relation(fields: [orderId],   references: [id], onDelete: Cascade)
  admin       User?       @relation("StatusChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([changedAt])
  @@map("order_status_history")
}


model Payment {
  id              Int               @id @default(autoincrement())
  // Références
  orderId         Int?              // lié à une commande (null si paiement manuel)
  invoiceId       Int?              // lié à une facture
  companyId       Int
  userId          Int               @db.UnsignedInt

  // Montants en EUR
  amount          Float
  currency        String            @default("EUR") @db.VarChar(10)
  exchangeRate    Float             @default(1)
  displayAmount   Float?            // montant dans la devise du client

  // Stripe
  stripePaymentIntentId String?     @db.VarChar(255)
  stripeChargeId        String?     @db.VarChar(255)
  stripeRefundId        String?     @db.VarChar(255)

  // Méthode de paiement
  method          PaymentMethodType @default(card)
  methodLabel     String?           @db.VarChar(100) // "Visa •••• 4242"
  last4           String?           @db.VarChar(4)
  brand           String?           @db.VarChar(30)  // "visa", "mastercard"...
  transactionId   String?           @db.VarChar(255) // ID externe (pour virement, chèque)

  // Statut
  status          PaymentStatus     @default(completed)
  failureMessage  String?           @db.Text

  // Notes
  notes           String?           @db.Text

  // Dates
  paidAt          DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  order           Order?            @relation(fields: [orderId],    references: [id], onDelete: SetNull)
  invoice         Invoice?          @relation(fields: [invoiceId],  references: [id], onDelete: SetNull)
  company         Company           @relation(fields: [companyId],  references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId],     references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([invoiceId])
  @@index([companyId])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}


model Affiliate {
  id              String              @id @default(uuid()) @db.Char(36)
  userId          Int?                @unique @db.UnsignedInt
  name            String?
  email           String?
  refCode         String              @unique
  revenue         Float               @default(0)
  stripeAccountId String?
  iban            String?
  createdAt       DateTime            @default(now())
  tracking        AffiliateTracking[]
  user            User?               @relation(fields: [userId], references: [id], onDelete: Cascade, map: "affiliates_userId_key")
  click           click[]
  payoutrequest   payoutrequest[]

  @@map("affiliates")
}

model AffiliateTracking {
  id          String    @id @default(uuid()) @db.Char(36)
  affiliateId String
  orderId     String?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId], map: "affiliate_tracking_affiliateId_fkey")
  @@index([orderId])
  @@map("affiliate_tracking")
}

model NotificationLog {
  id         String           @id @default(uuid()) @db.Char(36)
  type       NotificationType
  userId     String?
  locationId Int?
  status     String
  payload    String?
  error      String?
  createdAt  DateTime         @default(now())

  @@map("notification_logs")
}

model JobLog {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String
  status    String
  message   String?
  createdAt DateTime @default(now())

  @@map("job_logs")
}

model bundle {
  id            Int             @id @default(autoincrement())
  title         String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
  bundleproduct bundleproduct[]
}

model bundleproduct {
  id        Int     @id @default(autoincrement())
  bundleId  Int
  productId Int
  bundle    bundle  @relation(fields: [bundleId], references: [id], map: "BundleProduct_bundleId_fkey")
  product   Product @relation(fields: [productId], references: [id], map: "BundleProduct_productId_fkey")

  @@unique([bundleId, productId], map: "BundleProduct_bundleId_productId_key")
  @@index([productId], map: "BundleProduct_productId_fkey")
}

model click {
  id          String    @id
  affiliateId String
  ip          String?
  userAgent   String?
  referer     String?
  cookie      String?
  createdAt   DateTime  @default(now())
  affiliates  Affiliate @relation(fields: [affiliateId], references: [id], map: "Click_affiliateId_fkey")

  @@index([affiliateId], map: "Click_affiliateId_fkey")
}

model customization {
  id        String   @id
  orderId   String   @unique(map: "Customization_orderId_key")
  frontData String   @db.Text
  backData  String   @db.Text
  costCents Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model dashboardstat {
  id        String   @id
  key       String   @unique(map: "dashboardStat_key_key")
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}


  model Design {
    id          Int             @id @default(autoincrement())
    userId      Int             @db.UnsignedInt
    companyId   Int
    productId   Int
    status      DesignStatus    @default(draft)

    // ── Step 1 : Business ─────────────────────────────────────
    businessName    String?
    slogan          String?
    callToAction    String?  @default("Powered by RedVanta")
    ctaPaddingTop   Int?     @default(8)          // ← NOUVEAU : espacement CTA en px
    googlePlaceId   String?
    googleReviewUrl String?

    // ── Step 2 : Orientation & Logo ───────────────────────────
    orientation   DesignOrientation @default(landscape)
    logoUrl       String?
    logoPosition  String?  @default("left")       // ← NOUVEAU : "left"|"right"|"top-center"|"top-left"...
    logoSize      Int?     @default(32)            // ← NOUVEAU : hauteur logo en px

    // ── Step 2 : Couleurs ─────────────────────────────────────
    colorMode   String?  @default("single")        // "single" | "template"
    bgColor     String?  @default("#0B0D0F")
    textColor   String?  @default("#FFFFFF")
    accentColor String?  @default("#E10600")       // = qrColor côté front
    starColor   String?  @default("#F59E0B")
    iconsColor  String?  @default("#22C55E")        // ← NOUVEAU : couleur checkmarks/icônes

    // ── Step 2 : Template & Bandes ───────────────────────────
    templateName    String?
    gradient1       String?  @default("#0B0D0F")   // ← NOUVEAU : couleur gradient 1 du template
    gradient2       String?  @default("#1A1A1A")   // ← NOUVEAU : couleur gradient 2 du template
    accentBand1     String?  @default("#E10600")   // ← NOUVEAU : couleur bande 1
    accentBand2     String?  @default("#FF4444")   // ← NOUVEAU : couleur bande 2
    bandPosition    String?  @default("bottom")    // ← NOUVEAU : "top"|"bottom"|"hidden"
    frontBandHeight Int?     @default(22)          // ← NOUVEAU : hauteur bande avant (%)
    backBandHeight  Int?     @default(12)          // ← NOUVEAU : hauteur bande arrière (%)

    // ── Step 2 : Icônes ──────────────────────────────────────
    showNfcIcon    Boolean  @default(true)          // ← NOUVEAU
    showGoogleIcon Boolean  @default(true)          // ← NOUVEAU
    nfcIconSize    Int?     @default(16)
    googleLogoSize Int?     @default(20)

    // ── Step 2 : Typographie — Nom ───────────────────────────
    businessFont          String?  @default("Space Grotesk")
    businessFontSize      Int?     @default(16)
    businessFontWeight    String?  @default("Bold")
    businessFontSpacing   String?  @default("Normal")   // id : "tight"|"normal"|"wide"|"wider"
    businessLineHeight    String?  @default("1.2")
    businessAlign         String?  @default("Left")
    businessTextTransform String?  @default("none")      // ← NOUVEAU : "none"|"uppercase"|"capitalize"

    // ── Step 2 : Typographie — Slogan ────────────────────────
    sloganFont          String?  @default("Inter")
    sloganFontSize      Int?     @default(12)
    sloganFontWeight    String?  @default("Regular")
    sloganFontSpacing   String?  @default("Normal")
    sloganLineHeight    String?  @default("1.4")
    sloganAlign         String?  @default("Left")
    sloganTextTransform String?  @default("none")        // ← NOUVEAU

    // ── Step 2 : Texte d'ombre ───────────────────────────────
    textShadow  String?  @default("None")              // "None"|"Subtle"|"Medium"|"Strong"|"Outline"

    // ── Step 2 : Instructions ────────────────────────────────
    frontInstruction1  String?  @default("Approach the phone to the card")
    frontInstruction2  String?  @default("Tap to leave a review")
    backInstruction1   String?
    backInstruction2   String?

    instrFont           String?  @default("Space Grotesk")
    instrFontSize       Int?     @default(10)
    instrFontWeight     String?  @default("Regular")
    instrFontSpacing    String?  @default("Normal")
    instrLineHeight     String?  @default("1.4")
    instrAlign          String?  @default("Left")
    instrCheckboxStyle  String?  @default("checkmark")
    checkStrokeWidth    Decimal? @default(3.5) @db.Decimal(3,1)  // ← NOUVEAU : 1.0 à 5.0

    // ── Step 2 : QR Code ─────────────────────────────────────
    qrCodeStyle  String?  @default("Left")            // position : "top"|"bottom"|"left"|"right"
    qrCodeSize   Int?     @default(60)

    // ── Step 2 : Modèle de carte ─────────────────────────────
    cardModel  CardModel  @default(classic)

    // ── Step 2 : Positions drag-and-drop ─────────────────────
    // JSON complet des offsets par orientation/face/élément
    // Format : { "landscape": { "front": { "businessInfo": {x,y}, "instructions": {x,y}, ... }, "back": {...} }, "portrait": {...} }
    elementOffsets  Json?                               // ← NOUVEAU                            // ← NOUVEAU

    // ── Step 3 : Review ──────────────────────────────────────
    version       Int       @default(1)
    lastAutoSave  DateTime?
    validatedAt   DateTime?

    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    // Relations
    user        User        @relation(fields: [userId],    references: [id], onDelete: Cascade)
    company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
    product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    cartItem    CartItem[]
    orderItem   OrderItem[]
    versions    DesignVersion[]
    nfcCards  NFCCard[]

    @@index([userId, companyId])
    @@index([status])
    @@map("designs")
  }



model GooglePlaceCache {
  id              Int      @id @default(autoincrement())

  // Clé du cache — ce qui a été recherché
  placeId         String   @unique @db.VarChar(255)  // Google Place ID (stable)

  // Données retournées par Google Places Details
  name            String?  @db.VarChar(255)
  formattedAddress String? @db.VarChar(500)
  phone           String?  @db.VarChar(50)
  website         String?  @db.VarChar(500)
  // Coordonnées GPS
  lat             Float?
  lng             Float?
  // Notes et avis
  rating          Float?
  userRatingsTotal Int?
  // URL directe pour laisser un avis (lien QR code)
  // Format : https://search.google.com/local/writereview?placeid=ChIJxxx
  reviewUrl       String?  @db.VarChar(500)
  // Photo principale (reference pour l'API Photos)
  photoReference  String?  @db.Text
  photoUrl        String?  @db.VarChar(500)
  // Catégorie principale
  types           Json?    // tableau de types Google Places

  // Cache metadata
  cachedAt        DateTime @default(now())
  expiresAt       DateTime // cachedAt + 30 jours

  @@index([placeId])
  @@index([expiresAt])  // pour la purge automatique
  @@map("google_place_cache")
}


model DesignVersion {
  id        Int      @id @default(autoincrement())
  designId  Int
  version   Int
  snapshot  Json
  savedAt   DateTime @default(now())
  design    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@map("design_versions")
}

model emailQueue {
  id          String    @id
  to          String
  subject     String
  html        String    @db.Text
  text        String?   @db.Text
  processed   Boolean   @default(false)
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  @@map("emailqueue")
}




model NFCTag {
  id          Int          @id @default(autoincrement())

  // Identifiant physique de la puce (lu lors du scan NFC hardware)
  // Optionnel car pas toujours lisible (ex: iPhone)
  tagSerial   String?      @unique @db.VarChar(64)

  // Type de puce (optionnel — gestion de stock multi-puces)
  // ex: "NTAG213", "NTAG215", "NTAG216"
  chipType    String?      @db.VarChar(50)

  // Statut physique de la puce
  status      NfcTagStatus @default(NEW)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relation : une puce peut être associée à une carte métier
  card        NFCCard?

  @@index([status])
  @@map("nfc_tags")
}


// NFCCard — Logique métier (carte vendue + utilisée)
// Représente la carte telle que le client la reçoit et l'utilise
// Contient TOUT ce qui est business : user, location, design, product
// ─────────────────────────────────────────────────────────────
model NFCCard {
  id          Int           @id @default(autoincrement())

  // uid : identifiant UUID unique stable — utilisé dans l'URL /r/{uid}
  // C'est cet uid qui est encodé dans le payload (QR + puce NFC)
  uid         String        @unique @db.VarChar(36)

  // Relation vers la puce hardware (optionnel au moment de la création,
  // assigné lors de la production physique)
  tagId       Int?          @unique
  tag         NFCTag?       @relation(fields: [tagId], references: [id], onDelete: SetNull)

  // ── Logique métier ──────────────────────────────────────────
  companyId   Int           // company propriétaire
  userId      Int           @db.UnsignedInt  // admin/user qui a commandé
  locationId  Int?          // établissement associé
  designId    Int?          // design utilisé pour l'impression
  orderItemId Int?

  // ── Payload (URL encodée dans QR + puce NFC) ────────────────
  // Format : https://app.redvanta.com/r/{uid}
  // JAMAIS le lien Google directement
  payload     String?       @db.VarChar(500)

  // URL du fichier image QR code généré
  qrCodeUrl   String?       @db.VarChar(500)

  // ── Données Google (destination finale) ─────────────────────
  googlePlaceId   String?   @db.VarChar(255)
  googleReviewUrl String?   @db.VarChar(500)
  locationName    String?   @db.VarChar(255)
  locationAddress String?   @db.VarChar(500)

  // ── Cycle de vie ────────────────────────────────────────────
  status      NfcCardStatus @default(NOT_PROGRAMMED)
  active      Boolean       @default(false)  // false jusqu'à DELIVERED
  used        Boolean       @default(false)  // a été scannée au moins une fois

  // ── Analytics dénormalisés (performance) ────────────────────
  scanCount           Int       @default(0)
  googleRedirectCount Int       @default(0)
  lastScannedAt       DateTime?

  // ── Dates métier ────────────────────────────────────────────
  generatedAt  DateTime?   // = date paiement
  activatedAt  DateTime?   // = date livraison

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // ── Relations Prisma ────────────────────────────────────────
  company     Company       @relation(fields: [companyId],  references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId],     references: [id], onDelete: Cascade)
  location    Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  design      Design?       @relation(fields: [designId],   references: [id], onDelete: SetNull)
 orderItem   OrderItem?     @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  scans       NfcScan[]
  events      AnalyticsEvent[]

  @@index([companyId])
  @@index([locationId])
  @@index([status])
  @@index([active])
  @@map("nfc_cards")
}


// ─── Scans NFC / QR ──────────────────────────────────────────
// Chaque fois qu'un client scanne la carte → on enregistre le scan
// Permet de savoir : combien de scans, d'où ils viennent, à quelle heure
model NfcScan {
  id         Int      @id @default(autoincrement())
  cardUid    String   @db.VarChar(36)   // NFCCard.uid
  companyId  Int

  scanType   String   @default("qr") @db.VarChar(10) // "nfc" | "qr"
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  deviceType String?  @db.VarChar(20)
  country    String?  @db.VarChar(100)

  scannedAt  DateTime @default(now())

  card       NFCCard  @relation(fields: [cardUid],   references: [uid], onDelete: Cascade)
