model Invoice {
  id              Int           @id @default(autoincrement())
  invoiceNumber   String        @unique  // INV-2026-000001
  orderId         Int?          @unique  // lié à une commande (nullable si manuel)
  companyId       Int
  userId          Int           @db.UnsignedInt

  // Statut
  status          InvoiceStatus @default(paid)

  // Montants (toujours en EUR — devise de base)
  subtotal        Float
  taxAmount       Float         @default(0)
  shippingCost    Float         @default(0)
  total           Float
  paidAmount      Float         @default(0)

  // Devise d'affichage (si le client a payé dans une autre devise)
  currency        String        @default("EUR") @db.VarChar(10)
  exchangeRate    Float         @default(1)
  displayTotal    Float?        // total dans la devise du client

  // Paiement
  paymentMethod   String?       @db.VarChar(100)  // "Visa •••• 4242"
  stripePaymentIntentId String? @db.VarChar(255)
  paidAt          DateTime?

  // Adresse de facturation
  billingName     String?
  billingEmail    String?
  billingPhone    String?
  billingAddress  String?       @db.Text
  billingVat      String?       @db.VarChar(50)

  // Notes et conditions
  notes           String?       @db.Text
  terms           String?       @db.Text
  reference       String?       @db.VarChar(100)

  // Récurrence (pour les abonnements)
  isRecurring     Boolean       @default(false)
  recurringInterval String?     // "monthly" | "yearly"
  nextBillingDate DateTime?

  // Dates
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  order           Order?        @relation(fields: [orderId],    references: [id], onDelete: SetNull)
  company         Company       @relation(fields: [companyId],  references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId],     references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  refunds         Refund[]
  payments    Payment[]

  @@index([companyId])
  @@index([status])
  @@index([invoiceDate])
  @@map("invoices")
}

